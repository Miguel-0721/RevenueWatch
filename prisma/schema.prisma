generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserPlan {
  FREE
  GROWTH
  PRO
}

model User {
  id             String          @id @default(cuid())
  name           String?
  email          String?         @unique
  emailVerified  DateTime?
  image          String?
  plan           UserPlan        @default(FREE)
  stripeCustomerId String?
  stripeTestCustomerId String?
  stripeLiveCustomerId String?
  stripeSubscriptionId String?
  subscriptionStatus String?
  createdAt      DateTime        @default(now())

  accounts       Account[]
  sessions       Session[]
  stripeAccounts StripeAccount[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model StripeAccount {
  id              String   @id @default(cuid())
  stripeAccountId String   @unique
  status          String   @default("active")
  alertSensitivity String  @default("conservative")
  backfillStatus  String   @default("pending")
  lastBackfilledAt DateTime?
  backfillStartedAt DateTime?
  backfillError   String?
  name            String?
  createdAt       DateTime @default(now())

  userId String?
  user   User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model StripeEvent {
  id              String   @id @default(cuid())
  stripeEventId   String   @unique
  type            String
  stripeAccountId String?
  payload         String
  createdAt       DateTime @default(now())

  @@index([type])
  @@index([stripeAccountId])
}

model Alert {
  id              String    @id @default(cuid())
  type            String
  severity        String    @default("warning")
  status          String    @default("active")
  stripeAccountId String?
  stripeEventId   String    @unique
  message         String
  context         String?
  windowStart     DateTime
  windowEnd       DateTime
  cooldownUntil   DateTime?
  createdAt       DateTime  @default(now())

  @@index([type])
  @@index([severity])
  @@index([stripeAccountId])
}

model RevenueMetric {
  id              String   @id @default(cuid())
  stripeAccountId String?
  amount          Int
  currency        String?
  periodStart     DateTime
  periodEnd       DateTime
  hourOfDay       Int?
  dayOfWeek       Int?
  createdAt       DateTime @default(now())

  @@index([stripeAccountId])
  @@index([periodStart])
  @@index([dayOfWeek, hourOfDay])
}

model Lead {
  id              String   @id @default(cuid())
  name            String
  handle          String?
  profileUrl      String?
  productName     String?
  website         String?
  source          String
  sourceUrl       String?
  location        String?
  bio             String?
  postText        String?  @db.Text
  postUrl         String?
  pricingStatus   String   @default("unknown")
  likelyStripe    String   @default("unknown")
  painSignals     String[]
  score           Int      @default(0)
  scoreReasons    String[]
  status          String   @default("new")
  notes           String?  @db.Text
  suggestedReply  String?  @db.Text
  lastContactedAt DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([source])
  @@index([status])
  @@index([score])
}

model PostDraft {
  id              String   @id @default(cuid())
  title           String
  postType        String
  postText        String?  @db.Text
  screenshotUrl   String?
  screenshotNotes String?  @db.Text
  status          String   @default("draft")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([postType])
  @@index([status])
  @@index([updatedAt])
}
